# Copy this file to .env and fill in your values.

# --- Per-project GitHub tokens ---
# csrc-sdsu/mole
OSS_DASHBOARD_GITHUB_TOKEN_MOLE=github_pat_official_mole_token
GOATCOUNTER_API_KEY_MOLE=your_goatcounter_api_key

# Your fork (pritkc/mole) — use your fork admin token here for local testing.
OSS_DASHBOARD_GITHUB_TOKEN_MOLE_LOCAL=github_pat_your_fork_token_here
GOATCOUNTER_API_KEY_MOLE_LOCAL=your_goatcounter_api_key

# --- Local build defaults ---
# local-preview.sh builds both official MOLE and your fork unless you pass one
# project file as the first argument.
PROJECT_CONFIG=projects/mole-local.yml

# --- Vite base path ---
# For local dev with npm run dev, use /.
# local-preview.sh derives the GitHub Pages path automatically when unset.
VITE_BASE_PATH=/
